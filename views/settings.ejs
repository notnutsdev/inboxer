<%- include("base/head", { title: "User Settings" }) %>

<body>
    <%- include("base/nav") %>

    <%- include('base/error') %>
    <%- include('base/success') %>

    <div class="wrapper">
        <div style="max-width: 750px">
        <h1>User settings</h1>

        <div class="grid-3">
            <div class="pixel-container">
                <div class="before secondary-color-bg">
                    <h3>Change password</h3>
                    <form style="display: flex; gap: 10px; flex-direction: column;" method="post">
                        <input type="password" name="current_password" placeholder="Current password"> 
                        <input type="password" name="new_password" placeholder="New password">
                        <button type="submit" class="btn btn-secondary" name="change_password">Change password</button>
                    </form>
                </div>
                <div class="after"></div>
            </div>

            <div class="pixel-container" id="theme_color">
                <div class="before secondary-color-bg">
                    <h3>Theme</h3>
                    <form style="display: flex; gap: 10px; flex-direction: column;" method="post">
                        <div class="input-type">
                            <% if (locals.user.settings && locals.user.settings.theme_color == 'random') { %>
                                <div class="pixel-box">
                                    <svg version="1.1" xmlns="http://www.w3.org/2000/svg" width="32" height="32">
                                    <path d="M0 0 C6.6 0 13.2 0 20 0 C20 0.66 20 1.32 20 2 C20.66 2 21.32 2 22 2 C22 2.66 22 3.32 22 4 C22.66 4 23.32 4 24 4 C24 10.6 24 17.2 24 24 C23.34 24 22.68 24 22 24 C22 24.66 22 25.32 22 26 C21.34 26 20.68 26 20 26 C20 26.66 20 27.32 20 28 C13.4 28 6.8 28 0 28 C0 27.34 0 26.68 0 26 C-0.66 26 -1.32 26 -2 26 C-2 25.34 -2 24.68 -2 24 C-2.66 24 -3.32 24 -4 24 C-4 17.4 -4 10.8 -4 4 C-3.34 4 -2.68 4 -2 4 C-2 3.34 -2 2.68 -2 2 C-1.34 2 -0.68 2 0 2 C0 1.34 0 0.68 0 0 Z M2 6 C2 6.99 2 7.98 2 9 C2.99 9 3.98 9 5 9 C5 8.01 5 7.02 5 6 C4.01 6 3.02 6 2 6 Z M9 12 C9 12.99 9 13.98 9 15 C9.99 15 10.98 15 12 15 C12 14.01 12 13.02 12 12 C11.01 12 10.02 12 9 12 Z M15 19 C15 19.99 15 20.98 15 22 C15.99 22 16.98 22 18 22 C18 21.01 18 20.02 18 19 C17.01 19 16.02 19 15 19 Z " fill="#000000" transform="translate(6,2)"></path>
                                    </svg>
                                </div>
                            <% } else { %>
                                <input type="color" name="theme_color" value="<%= locals.user.settings.theme_color %>"> 
                            <% } %>
                        </div>

                        <a>> Switch</a>

                        <button type="submit" class="btn btn-secondary" name="change_theme_color">Change theme color</button>
                    </form>
                </div>
                <div class="after"></div>
            </div>

            <div class="pixel-container">
                <div class="before secondary-color-bg">
                    <h3>NSFW Image Checking</h3>
                    <form style="display: flex; gap: 10px; flex-direction: column;" method="post">
                        <input type="checkbox" name="nsfw_checker_activated" id="nsfw_checker_activated" <% if (locals.user.settings && user.settings.nsfw_check == true) { %>checked<% } %>>
                        <button type="submit" class="btn btn-secondary" name="nsfw_checker">Update</button>
                    </form>
                </div>
                <div class="after"></div>
            </div>

            <div class="pixel-container">
                <div class="before secondary-color-bg">
                    <h3 style="color: red; text-shadow: 0px 0px 2px black;">Danger Zone</h3>
                    <a href="/settings/deleteaccount" class="btn btn-danger">Delete account</a>
                </div>
                <div class="after"></div>
            </div>

        </div>
        </div>
    </div>

    <script src="/js/usersettings.js" defer></script>

    <%- include("base/footer") %>
</body>
</html>