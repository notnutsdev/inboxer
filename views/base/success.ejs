<%# Success message %>
<% if (locals.success) { %>
    <div class="wrapper" style="margin-top: 25px;">
        <div id="success" class="pixel-container">
            <div class="before">
                <div><img src="/img/check.png" alt="" height="30px" width="30px"></div>
                <%- success %>
            </div>
            <div class="after"></div>
        </div>
    </div>
<% } %>