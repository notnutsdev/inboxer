<%- include("base/head", { title: "New post" }) %>

<body>
    <%- include("base/nav") %>

    <%- include('base/error') %>

    <div class="wrapper">
        <div class="container pixel-border form-container text-center">
            <h2>Create a new post</h2>

            <form action="/create" method="post" id="create">
                <label for="username">Your username</label>
                <input type="text" name="username" id="username" placeholder="Username here">
                
                <label for="content">Content</label>
                <textarea name="content" id="content" placeholder="Content here"></textarea>
                
                <button class="btn" type="submit">Post</button>
            </form>
        </div>
    </div>

    <%- include("base/footer") %>
</body>
</html>