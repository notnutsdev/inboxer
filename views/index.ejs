<%- include("base/head", { title: "Inboxer", og_data: { title: "Inboxer", description: "Anonymous text sharing platform, with style." } }) %>
<body>
    <%- include("base/nav") %>
    <%- include("base/announcement") %>

    <div style="display: flex; justify-content: center;">
    <div style="display: flex; flex-direction: column; align-items: start; gap: 25px; padding: 20px 5px; padding-top: 10px;">

        <%# User action bar %>
        <% if (locals.user) { %>
            <div class="user_controls">
                <a href="/create" style="flex-grow: 1"><button class="btn" style="max-width: 200px; padding: 0px 5px;">Create a post</button></a>
                <div class="flex align-items-center gap-5">
                    <a class="flex align-items-center group-<%= user.group %>" href="/user/<%= user.username %>"><%= user.username %></a>
                    <a class="flex align-items-center" href="/settings"><img src="/img/settings.png" height="20px"></a>
                    <a class="flex align-items-center" href="/logout"><img src="/img/logout.png" height="20px"></a>
                    <%# find something else than flex align-items-center for each item %>
                </div>
            </div>
        <% } else { %>
            <div style="align-self: center; margin-top: 25px">
                <a href="/create"><button class="btn" style="max-width: 200px; padding: 0px 5px;">Create a post</button></a>
            </div>

            <div class="pixel-container">
                <div class="before flex align-items-center" style="background-color: rgb(231, 187, 105);">
                    <img src="/img/info.png" height="15px" style="opacity: 0.5; margin-right: 5px">
                    <div>Seems like you aren't logged in. <a href="/auth/login" class="regular">Log in</a> or <a href="/auth/register" class="regular">sign up</a> today!</div>
                </div>

                <div class="after"></div>
            </div>
        <% } %>
        
        <div id="posts">
            <h2 style="margin-top: 0px;">Random posts</h2>

            <% for (let i = 0; i < posts.length; i++) { %>
                <% const post = posts[i]; %>
                <div>
                    > <a href="/post/<%- post.uid %>" class="regular"><%- post.uid %></a> by <a href="<% if (post.user.group == 0) { %>/throwaway<% } else { %>/user/<%= post.user.username %><% } %>"><%- include("components/username_span", { author: post.user }) %></a>
                </div>
            <% } %>
        </div>

        <div>
            <h2>How does this work?</h2>

            <div id="about">
                <div class="about_item">
                    <img src="/img/write.png" height="50px">
                    <div>
                        <h3>Write stuff.</h3>
                        Write anything you want, as long as it respects the <a href="/rules" class="regular">site rules.</a>
                    </div>
                </div>

                <div class="about_item">
                    <img src="/img/share.png" height="50px">
                    <div>
                        <h3>Share it.</h3>
                        Share your masterpiece with your friends, family and collegues. It stays here forever.
                    </div>
                </div>

                <div class="about_item">
                    <img src="/img/earth.png" height="50px">
                    <div>
                        <h3>Discover.</h3>
                        Every post is public. Users can stumble upon your post randomly with the "Random" button at the top.
                    </div>
                </div>
            </div>
        </div>

        <div id="useful_links">
            <h2>Useful links</h2>

            <div style="display: flex; flex-direction: column; align-items: start;">
                <span>> <a href="/formatting" class="regular">Format your posts</a></span>
                <span>> <a href="/rules" class="regular">Site rules</a></span>
                <span>> <a href="/socials" class="regular">Our socials</a></span>
                <span>> <a href="/contact" class="regular">Contact us</a></span>
                <span>> <a href="/report" class="regular">Report innapropriate content</a></span>
                <span>> <a href="https://github.com/notnutsdev/inboxer" class="regular">GitHub</a></span>
            </div>
        </div>
    </div>
    </div>

    <%- include("base/footer") %>
</body>
</html>