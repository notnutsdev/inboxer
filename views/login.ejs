<%- include("base/head", { title: "Staff Login" }) %>

<body>
    <%- include("base/nav") %>

    <%- include('base/error') %>
    <%- include('base/success') %>

    <% if (!locals.success) { %>
        <div class="wrapper">
            <div class="container pixel-border form-container text-center">
                <h2>Welcome back!</h2>

                <form method="post">
                    <label for="username">Username</label>
                    <input type="text" name="username" id="username" placeholder="Username here"><br>
                    
                    <label for="password">Password</label>
                    <input style="margin-top: 10px" type="password" name="password" id="password" placeholder="Password here"><br>
                    
                    <button class="btn" type="submit" style="margin-top: 10px">Sign in</button>
                </form>
            </div>
        </div>
    <% } %>

    <%- include("base/footer") %>
</body>
</html>