<% if (locals.error) { %>
    <%- include("base/head", { title: "Error" }) %>
<% } else { %>
    <%- include("base/head", { title: `User - ${locals.profile.username}` }) %>
<% } %>

<body>
    <%- include("base/nav") %>

    <%- include('base/error') %>

    <div class="flex justify-content-center" style="width: 100%;">
    <div style="max-width: 500px; width: 100%">
        <div>
            <h2 style="margin-top: 30px;">User Profile</h2>
            <h2 style="margin-bottom: 0px;"><%- include("components/username_span", { author: locals.profile }) %></h2>

            <% const creation_date = new Date(profile.creation_date*1000) %>
            <div class="opacity-50">Joined <%= creation_date.toLocaleString('en-EN', {month: "long", day: "numeric", year: "numeric"}) %></div>

            <%# Staff actions %>
            <% if (user.group >= 3) { %>
                <a href="/moderation/ban?uid=<%= locals.profile.uid %>" class="btn btn-danger"><img title="Ban User" src="/img/ban.png" height="17px"></a>
            <% } %>
        </div>

        <% if (locals.posts) { %>
            <h3>Posts:</h3>
            <% if (total_pages >= 1) { %>
                <div class="post-list">
                    <% posts.forEach(value => { %>
                        <span>> <a href="/post/<%= value.uid %>" class="regular"><%= value.uid %></a></span>
                    <% }) %>
                </div>

                <%# pagination buttons %>
                <div class="btn-row" style="padding: 10px">
                    <% if (page-1 > 0) { %>
                        <a href="/user/<%= profile.username %>?page=<%= page-1 %>" class="btn"><%= page-1 %></a>
                    <% } %>
                    <button class="btn"><%= page %></button>
                    <% if (page+1 <= total_pages) { %>
                        <a href="/user/<%= profile.username %>?page=<%= page+1 %>" class="btn"><%= page+1 %></a>
                    <% } %>
                </div>
            <% } else { %>
                <div class="opacity-50">
                    This user hasn't posted anything yet.
                </div>
            <% } %>
        <% } %>
    </div>
    </div>

    <%- include("base/footer") %>
</body>
</html>